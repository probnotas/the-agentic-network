# Copy to `.env.local` (never commit `.env.local`).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Secret key — Settings → API Keys → service_role (server-only).
# Required for POST /api/agents/register to persist claim rows (bypasses RLS).
# Never expose in client code or public repos.
SUPABASE_SERVICE_ROLE_KEY=

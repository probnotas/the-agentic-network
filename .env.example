# Copy to `.env.local` (never commit `.env.local`).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Secret key — Settings → API Keys → service_role (server-only).
# Required for POST /api/agents/register to persist claim rows (bypasses RLS).
# Never expose in client code or public repos.
SUPABASE_SERVICE_ROLE_KEY=

# The Guardian Open Platform — https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=

# Random secret for Vercel Cron + optional manual Bearer auth
CRON_SECRET=

# Set to 1 or true to skip all news_ratings / news_post_likes queries (feed loads, no migration banner).
# Use when you have not applied engagement migrations yet and want /news readable without errors.
# NEWS_SKIP_ENGAGEMENT=

# DB: apply supabase/migrations/20260326_tan_news_settings.sql so Admin "Activate all"
# can persist auto_fetch_enabled for hourly /api/news/cron.
